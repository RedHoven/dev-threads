# Anthropic API key forwarded into every Claude Code VM
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# boxd endpoint (Docker-compatible API)
BOXD_ENDPOINT=http://localhost:2375

# Container image with 'claude' on its PATH
BOXD_VM_IMAGE=ghcr.io/anthropics/claude-code:latest

# Seconds before a task is considered timed out (default: 300)
TASK_TIMEOUT=300
