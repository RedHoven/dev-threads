# ── OpenClaw / kiloclaw ──────────────────────────────────────────────────────
OPENCLAW_API_KEY=your_openclaw_api_key_here
OPENCLAW_BASE_URL=https://api.kiloclaw.io

# ── boxd VM pool ─────────────────────────────────────────────────────────────
BOXD_ENDPOINT=http://localhost:2375
BOXD_VM_IMAGE=claude-code:latest

# ── Context persistence ───────────────────────────────────────────────────────
# Path where thread context snapshots are stored.  ~ is expanded.
CONTEXT_STORE_PATH=~/.dev-threads/contexts

# ── Voice interface ───────────────────────────────────────────────────────────
VOICE_WAKE_WORD=hey threads
VOICE_LANGUAGE=en-US

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
